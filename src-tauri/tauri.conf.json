{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Miku-versi",
  "version": "0.1.0",
  "identifier": "d.miku.versi",
  "build": {
    "beforeDevCommand": "npm run build",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Miku-versi",
        "width": 390,
        "height": 740,
        "minWidth": 320,
        "minHeight": 560,
        "resizable": true,
        "backgroundColor": "#25cfd0"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "category": "Game",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
